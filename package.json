{
  "name": "moontv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm gen:manifest && tsx server.ts",
    "build": "pnpm gen:manifest && next build",
    "build:pwa": "pnpm gen:manifest && cross-env ENABLE_PWA=1 next build",
    "build:cloudflare": "cross-env BUILD_TARGET=cloudflare pnpm gen:manifest && npx @opennextjs/cloudflare build",
    "start": "tsx start.ts",
    "preview:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "lint": "eslint src --quiet",
    "lint:fix": "eslint src --fix && pnpm format",
    "lint:strict": "eslint --max-warnings=0 src",
    "typecheck": "tsc --noEmit --incremental false",
    "test:watch": "jest --watch",
    "test": "jest --passWithNoTests",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "gen:manifest": "tsx scripts/generate-manifest.ts",
    "postbuild": "echo 'Build completed - sitemap generation disabled'",
    "prepare": "husky install",
    "watch-room:server": "tsx server/watch-room-standalone-server.ts --port 3001 --auth YOUR_SECRET_KEY",
    "init:sqlite": "tsx scripts/init-sqlite.ts",
    "init:postgres": "tsx scripts/init-postgres.ts",
    "db:reset": "tsx scripts/reset-sqlite.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@types/crypto-js": "^4.2.2",
    "@types/nprogress": "^0.2.3",
    "@upstash/redis": "^1.25.0",
    "@vercel/postgres": "^0.10.0",
    "@vidstack/react": "^1.12.13",
    "anime4k-webgpu": "^1.0.0",
    "artplayer": "^5.3.0",
    "artplayer-plugin-danmuku": "^5.2.0",
    "better-sqlite3": "^12.6.2",
    "bs58": "^6.0.0",
    "cheerio": "^1.1.2",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "flv.js": "^1.6.2",
    "framer-motion": "^12.18.1",
    "he": "^1.2.0",
    "hls.js": "^1.6.10",
    "https-proxy-agent": "^7.0.6",
    "lucide-react": "^0.438.0",
    "media-icons": "^1.1.5",
    "mux.js": "^6.3.0",
    "nanoid": "^5.1.6",
    "next": "^15.5.12",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.12",
    "nprogress": "^0.2.0",
    "opencc-js": "^1.0.5",
    "parse-torrent-name": "^0.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.4.0",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.3",
    "redis": "^4.6.7",
    "remark-gfm": "^3.0.1",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swiper": "^11.2.8",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.19.2",
    "vidstack": "^0.6.15",
    "xml2js": "^0.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^16.3.0",
    "@commitlint/config-conventional": "^16.2.4",
    "@opennextjs/cloudflare": "^1.17.1",
    "@rollup/pluginutils": "^5.3.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^30.0.0",
    "@types/he": "^1.2.3",
    "@types/node": "24.0.3",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.12",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^7.0.4",
    "jest": "^27.5.1",
    "lint-staged": "^12.5.0",
    "next-router-mock": "^0.9.0",
    "postcss": "^8.5.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vercel": "^50.4.10",
    "webpack-obfuscator": "^3.5.1",
    "wrangler": "^4.65.0",
    "workbox-build": "6.5.4"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --quiet",
      "prettier -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier -w"
    ]
  },
  "packageManager": "pnpm@10.14.0"
}
